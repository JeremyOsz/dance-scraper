#
# Environment example for London Dance Calendar
# Copy this file to `.env.local` and fill in the values.
#

# Public site URL (used for SEO / OpenGraph). Include protocol, no trailing slash.
# Example: https://londondancecalendar.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Search Console verification token.
# If set, Next.js emits <meta name="google-site-verification" ... /> automatically.
GOOGLE_SITE_VERIFICATION=your_google_verification_token

# Optional public contact email for venue requests in the UI.
NEXT_PUBLIC_VENUE_REQUEST_EMAIL=hello@dance-scraper.local

# Email address that will receive contact form submissions.
CONTACT_EMAIL=you@example.com

# Resend API key for sending contact form emails.
RESEND_API_KEY=your_resend_api_key_here

# From address verified in Resend (e.g. no-reply@yourdomain.com).
FROM_EMAIL=no-reply@yourdomain.com

